# Configuración del launcher (NO credenciales: esas se cargan desde el HTML).
# Copiá este archivo a ".env" y ajustá si hace falta.

# Puerto donde levanta el launcher HTML
PORT=4599

# Mostrar el navegador (0) o correr oculto/headless (1)
HEADLESS=0

# Demora entre acciones en ms (para poder seguir el flujo a ojo)
SLOWMO=80

# Dejar el navegador abierto al terminar el test (1) para inspeccionar el estado
KEEP_OPEN=0
